# ── Dependencies ──────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Environment / secrets ─────────────────────────────────
# .env holds TEST_TARGET_API_KEY — never commit it.
# .env.example IS tracked as the template.
.env
.env.local
.env.*.local

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Caches ────────────────────────────────────────────────
.vite/
.cache/
coverage/
.pnpm-store/

# ── Editor / OS ───────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
# .vscode/ is left untracked by default. If you want to share
# workspace settings, remove this line and commit settings.json.
.vscode/
