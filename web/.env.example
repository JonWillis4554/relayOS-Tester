# Shared password for the web UI login page.
# Set this to the same value as TEST_TARGET_API_KEY in the root .env.
# It is used as both the login gate and the API bearer token.
VITE_APP_PASSWORD=

# (Local dev only) Proxy target for the Vite dev server.
# When running via docker compose this is set automatically to http://test-target:3100.
# Override here only if running `pnpm dev` directly outside compose.
API_TARGET=http://localhost:3100
