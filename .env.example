# Bearer token for API authentication.
# Generate with: openssl rand -hex 16
TEST_TARGET_API_KEY=

# Full Postgres connection string.
# When running via docker compose, the host is the "postgres" service name.
# For a local (non-Docker) Postgres, use localhost.
DATABASE_URL=postgres://relayos:relayos@localhost:5432/relayos_test

# HTTP port for the service.
PORT=3000
